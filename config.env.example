# plex-qbt-throttle configuration
# Copy this file to config.env and fill in your values.
# NEVER commit config.env to git.

# =============================================================================
# Plex
# =============================================================================
# Your Plex server URL (default: http://localhost:32400)
PLEX_URL=http://localhost:32400

# Your Plex authentication token
# Find it: Settings → Account → "XML" link → look for X-Plex-Token in the URL
# Or: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=

# =============================================================================
# qBittorrent instances
# =============================================================================
# Comma-separated list of qBittorrent instances in host:port:user:pass format.
# All listed instances will have their limits adjusted simultaneously.
# Example — two instances:
#   QBT_INSTANCES=localhost:8080:admin:yourpassword,localhost:8081:admin:yourpassword
QBT_INSTANCES=localhost:8080:admin:adminadmin

# =============================================================================
# Bandwidth settings
# =============================================================================
# Your total line speed in bits per second.
# Examples: 1000000000 = 1 Gbps, 500000000 = 500 Mbps, 100000000 = 100 Mbps
TOTAL_BANDWIDTH_BPS=1000000000

# Fraction of remaining bandwidth (after Plex) to allocate to qBittorrent download.
# 0.8 = qbt gets 80% of what Plex isn't using.
QBT_HEADROOM_FRACTION=0.8

# Same for upload (usually less contested, so higher fraction is fine).
QBT_UPLOAD_FRACTION=0.9

# Hard floor: never throttle qbt below these values (bytes/sec).
# Prevents qbt from being completely starved.
# Default: 10 MB/s down, 5 MB/s up
MIN_QBT_DL_BYTES=10485760
MIN_QBT_UL_BYTES=5242880

# Safety multiplier on top of Plex's reported bitrate (to account for
# buffering bursts and overhead). 1.25 = assume 25% headroom.
PLEX_OVERHEAD_FACTOR=1.25

# =============================================================================
# Tuning
# =============================================================================
# Seconds between Plex session polls
POLL_INTERVAL=15

# HTTP request timeout in seconds
REQUEST_TIMEOUT=10

# Log file path (default: throttle.log in the script directory)
# LOG_FILE=/path/to/throttle.log
