# qbt-flow configuration
# Copy this file to config.env and fill in your values.
# NEVER commit config.env to git.

# =============================================================================
# Media servers — set URL + token for each server you want to poll.
# Streams from all configured servers are aggregated.
# =============================================================================

# --- Plex ---
# Token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
#PLEX_URL=http://localhost:32400
#PLEX_TOKEN=

# --- Jellyfin ---
# API key: Dashboard → API Keys → +
#JELLYFIN_URL=http://localhost:8096
#JELLYFIN_TOKEN=

# --- Emby ---
# API key: Dashboard → API Keys → +
#EMBY_URL=http://localhost:8920
#EMBY_TOKEN=

# =============================================================================
# qBittorrent instances
# =============================================================================
# Comma-separated list of qBittorrent instances in host:port:user:pass[:scheme] format.
# All listed instances will have their limits adjusted simultaneously.
# Append :https if the instance uses TLS (default: http).
# Example — two instances, one with HTTPS:
#   QBT_INSTANCES=localhost:8080:admin:yourpassword,myserver:8443:admin:yourpassword:https
QBT_INSTANCES=localhost:8080:admin:yourpassword

# =============================================================================
# Bandwidth settings
# =============================================================================
# Your total download line speed.  Supports human-readable suffixes:
#
#   Bits/sec (SI, base-1000 — what your ISP advertises):
#     Kbps, Mbps, Gbps
#
#   Bytes/sec (binary, base-1024 — what download managers show):
#     KB/s, MB/s, GB/s
#
# Spaces between the number and suffix are fine. Case-insensitive.
# Plain numbers without a suffix are treated as bits/sec.
#
# Examples (all of these are equivalent ways to say ~1 Gbps):
#   1Gbps      1 Gbps      1000Mbps      1000 Mbps
#   125MB/s    125 MB/s    128000KB/s
#
# More examples:
#   500Mbps  = 500 Mbps  ≈ 62.5 MB/s     (500 Mbit fibre)
#   100Mbps  = 100 Mbps  ≈ 12.5 MB/s     (100 Mbit cable)
#   50Mbps   = 50 Mbps   ≈ 6.25 MB/s     (typical upload)
#   0.5Gbps  = 500 Mbps  ≈ 62.5 MB/s     (decimals work too)
#
TOTAL_BANDWIDTH=1Gbps

# Your upload line speed (defaults to TOTAL_BANDWIDTH if not set).
# Set this if your connection is asymmetric (e.g. 1 Gbps down / 50 Mbps up).
# TOTAL_UPLOAD=50Mbps

# Fraction of remaining bandwidth (after media streams) to allocate to qBittorrent download.
# Default: 1.0 (no download throttling). Media streams consume your *upload*
# bandwidth (server → viewer), so download throttling is usually unnecessary.
# Lower this only if you experience issues like bufferbloat without router QoS.
#QBT_HEADROOM_FRACTION=1.0

# Fraction of remaining *upload* bandwidth to give qBittorrent.
# This is the setting that actually matters for protecting media streams.
QBT_UPLOAD_FRACTION=0.9

# Hard floor: never throttle qbt below these values.
# Prevents qbt from being completely starved.
# Default: 10 MB/s down, 5 MB/s up
MIN_QBT_DL=10MB/s
MIN_QBT_UL=5MB/s

# Safety multiplier on top of reported stream bitrates (to account for
# buffering bursts and overhead). 1.25 = assume 25% headroom.
PLEX_OVERHEAD_FACTOR=1.25

# When multiple qBittorrent instances are configured, split the calculated
# bandwidth evenly between them (true) or give each the full amount (false).
# Default: true
QBT_SPLIT_BETWEEN_INSTANCES=true

# =============================================================================
# Racing window
# =============================================================================
# During the racing window, one instance (the "racing" instance) gets priority
# bandwidth while all other instances are hard-capped. This prevents long-term
# media downloads from competing with time-sensitive racing torrents.
# Disabled by default.
#RACING_WINDOW_ENABLED=true

# Racing window hours (24h format). Supports wrapping midnight (e.g. 22→7).
#RACING_WINDOW_START=0
#RACING_WINDOW_END=7

# Port of the racing qBittorrent instance (gets priority during the window)
#RACING_INSTANCE_PORT=39001

# Hard caps for non-racing instances during the window.
# Default: 1 MB/s each
#RACING_NON_RACING_DL_LIMIT=1MB/s
#RACING_NON_RACING_UL_LIMIT=1MB/s

# =============================================================================
# Tuning
# =============================================================================
# Seconds between media-server session polls
POLL_INTERVAL=15

# HTTP request timeout in seconds
REQUEST_TIMEOUT=10

# What to do when the media server is unreachable: "keep" (retain last limits)
# or "unlimited" (remove all limits). Default: keep
PLEX_UNREACHABLE_ACTION=keep

# Gradual ramp-up: number of cycles (including final unlimited) to reach
# full speed after all streams stop (0 = instant). Each step doubles the
# limit, so with RAMP_UP_STEPS=3 and POLL_INTERVAL=15 the ramp takes ~45s.
RAMP_UP_STEPS=3

# Max exponential-backoff interval (seconds) when the media server is
# unreachable. Retries start at 2s and double each failure up to this cap.
BACKOFF_MAX_INTERVAL=300

# Status / metrics HTTP endpoint. Set to a port to enable (e.g. 9101).
# GET /status → JSON snapshot, GET /metrics → Prometheus text format.
# 0 = disabled (default).
#STATUS_PORT=9101

# Log file path (default: throttle.log in the script directory)
# LOG_FILE=/path/to/throttle.log

# Log level: DEBUG, INFO, WARNING, ERROR. Default: INFO
# LOG_LEVEL=INFO
