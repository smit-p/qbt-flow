# qbt-flow configuration
# Copy this file to config.env and fill in your values.
# NEVER commit config.env to git.

# =============================================================================
# Plex
# =============================================================================
# Your Plex server URL (default: http://localhost:32400)
PLEX_URL=http://localhost:32400

# Your Plex authentication token
# Find it: Settings → Account → "XML" link → look for X-Plex-Token in the URL
# Or: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=

# =============================================================================
# qBittorrent instances
# =============================================================================
# Comma-separated list of qBittorrent instances in host:port:user:pass[:scheme] format.
# All listed instances will have their limits adjusted simultaneously.
# Append :https if the instance uses TLS (default: http).
# Example — two instances, one with HTTPS:
#   QBT_INSTANCES=localhost:8080:admin:yourpassword,myserver:8443:admin:yourpassword:https
QBT_INSTANCES=localhost:8080:admin:adminadmin

# =============================================================================
# Bandwidth settings
# =============================================================================
# Your total download line speed in bits per second.
# Examples: 1000000000 = 1 Gbps, 500000000 = 500 Mbps, 100000000 = 100 Mbps
TOTAL_BANDWIDTH_BPS=1000000000

# Your upload line speed in bits per second.
# Defaults to TOTAL_BANDWIDTH_BPS if not set. Set this if your connection is
# asymmetric (e.g. 1 Gbps down / 50 Mbps up).
# TOTAL_UPLOAD_BPS=50000000

# Fraction of remaining bandwidth (after Plex) to allocate to qBittorrent download.
# 0.8 = qbt gets 80% of what Plex isn't using.
QBT_HEADROOM_FRACTION=0.8

# Same for upload (usually less contested, so higher fraction is fine).
QBT_UPLOAD_FRACTION=0.9

# Hard floor: never throttle qbt below these values (bytes/sec).
# Prevents qbt from being completely starved.
# Default: 10 MB/s down, 5 MB/s up
MIN_QBT_DL_BYTES=10485760
MIN_QBT_UL_BYTES=5242880

# Safety multiplier on top of Plex's reported bitrate (to account for
# buffering bursts and overhead). 1.25 = assume 25% headroom.
PLEX_OVERHEAD_FACTOR=1.25

# When multiple qBittorrent instances are configured, split the calculated
# bandwidth evenly between them (true) or give each the full amount (false).
# Default: true
QBT_SPLIT_BETWEEN_INSTANCES=true

# =============================================================================
# Racing window
# =============================================================================
# During the racing window, one instance (the "racing" instance) gets priority
# bandwidth while all other instances are hard-capped. This prevents long-term
# media downloads from competing with time-sensitive racing torrents.
# Disabled by default.
#RACING_WINDOW_ENABLED=true

# Racing window hours (24h format). Supports wrapping midnight (e.g. 22→7).
#RACING_WINDOW_START=0
#RACING_WINDOW_END=7

# Port of the racing qBittorrent instance (gets priority during the window)
#RACING_INSTANCE_PORT=39001

# Hard caps for non-racing instances during the window (bytes/sec).
# Default: 5 MB/s each
#RACING_NON_RACING_DL_LIMIT=5242880
#RACING_NON_RACING_UL_LIMIT=5242880

# =============================================================================
# Tuning
# =============================================================================
# Seconds between Plex session polls
POLL_INTERVAL=15

# HTTP request timeout in seconds
REQUEST_TIMEOUT=10

# What to do when Plex is unreachable: "keep" (retain last limits) or
# "unlimited" (remove all limits). Default: keep
PLEX_UNREACHABLE_ACTION=keep

# Log file path (default: throttle.log in the script directory)
# LOG_FILE=/path/to/throttle.log

# Log level: DEBUG, INFO, WARNING, ERROR. Default: INFO
# LOG_LEVEL=INFO
